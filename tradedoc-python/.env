# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tradedoc
DB_USER=root
DB_PASSWORD=root

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# OCR 引擎模式: aliyun_api / local_model / mock / auto
# auto = 按优先级自动选择: aliyun_api > local_model > mock
OCR_ENGINE=auto
OCR_MODEL_PATH=D:/ai_models/Logics-Parsing-v2
OCR_CONFIDENCE_THRESHOLD=80

# 阿里云 DashScope API Key（方案A：qwen-vl-ocr）
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-f0706a258a4b4686a0b46032bb275c0a

# 文件存储（与PHP共享）
FILE_STORAGE_PATH=D:/work/product/business_file_management/tradedoc/storage/app/private

# 服务端口
API_HOST=127.0.0.1
API_PORT=8100

# # 文件位置: tradedoc-python/.env

# # 方案A: 阿里云API（推荐，无需GPU）
# OCR_ENGINE=aliyun_api
